DATABASE_URL=postgresql://postgres:pass@localhost:5433/hookahmix
SECRET_KEY=change_me_in_production

# docker-compose.yml interpolates this into POSTGRES_PASSWORD (db service)
# and into DATABASE_URL (api service). Required — no default, set before `docker-compose up`.
POSTGRES_PASSWORD=change_me_in_production

# YooKassa (get values from https://yookassa.ru/my/merchant/integration/api-keys)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=hooka3://bundle_success

# 2GIS Catalog API — real-time venue busyness. Get demo key at https://platform.2gis.ru
DGIS_API_KEY=

# Telegram bot for manager busyness polling. Create via @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=hooka3_busyness_bot
BUSYNESS_POLL_INTERVAL_MIN=30
BUSYNESS_POLL_HOUR_START=14
BUSYNESS_POLL_HOUR_END=2
